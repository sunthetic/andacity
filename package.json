{
  "name": "@sunthetic/andacity",
  "version": "0.2.0",
  "description": "An experience-driven travel booking and discovery-first travel planning site offering search modes for destinations, hotels, car rentals, and flights.",
  "license": "SEE LICENSE IN LICENSE.md",
  "repository": {
    "type": "git",
    "url": "https://github.com/sunthetic/andacity.git"
  },
  "keywords": [
    "qwik",
    "tailwind",
    "typescript",
    "travel",
    "booking",
    "discovery",
    "experiennce",
    "planning",
    "prototype",
    "sunthetic",
    "sunthetic media",
    "andacity",
    "andacity.com"
  ],
  "authors": [
    {
      "name": "Sunthetic Media",
      "email": "andacity@sunthetic.media",
      "url": "https://sunthetic.com"
    },
    {
      "name": "Alden Gillespy",
      "email": "61519345+brazenest@users.noreply.github.com",
      "url": "https://aldengillespy.com"
    }
  ],
  "bugs": {
    "url": "https://github.com/sunthetic/andacity/issues"
  },
  "homepage": "https://github.com/sunthetic/andacity#readme",
  "sideEffects": false,
  "engines": {
    "node": "^18.17.0 || ^20.3.0 || >=21.0.0"
  },
  "engines-annotation": "Mostly required by sharp which needs a Node-API v9 compatible runtime",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "qwik build",
    "build.client": "vite build",
    "build.preview": "vite build --ssr src/entry.preview.tsx",
    "build.types": "tsc --incremental --noEmit",
    "test": "vitest run",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:push": "drizzle-kit push",
    "db:seed": "node scripts/seed/postgres-seed.mjs --mode apply --vertical all --reset",
    "db:seed:90": "node scripts/seed/postgres-seed.mjs --mode apply --vertical all --reset --horizon-days 90",
    "db:seed:120": "node scripts/seed/postgres-seed.mjs --mode apply --vertical all --reset --horizon-days 120",
    "db:seed:180": "node scripts/seed/postgres-seed.mjs --mode apply --vertical all --reset --horizon-days 180",
    "db:seed:cars": "node scripts/seed/postgres-seed.mjs --mode apply --vertical cars",
    "db:seed:flights": "node scripts/seed/postgres-seed.mjs --mode apply --vertical flights",
    "db:seed:hotels": "node scripts/seed/postgres-seed.mjs --mode apply --vertical hotels",
    "db:seed:plan": "node scripts/seed/postgres-seed.mjs --mode plan --vertical all",
    "db:validate:inventory": "node scripts/validate/inventory-density.mjs",
    "db:studio": "drizzle-kit studio",
    "deploy": "echo 'Run \"npm run qwik add\" to install a server adapter'",
    "dev": "vite --mode ssr",
    "dev.debug": "node --inspect-brk ./node_modules/vite/bin/vite.js --mode ssr --force",
    "fmt": "prettier --write .",
    "fmt.check": "prettier --check .",
    "lint": "eslint \"src/**/*.ts*\"",
    "preview": "qwik build preview && vite preview --open",
    "seed:generate": "node scripts/seed/generate.mjs",
    "seed:generate:cars": "node scripts/seed/generate.mjs --vertical cars",
    "seed:generate:flights": "node scripts/seed/generate.mjs --vertical flights",
    "seed:generate:hotels": "node scripts/seed/generate.mjs --vertical hotels",
    "seed:generate:90": "node scripts/seed/generate.mjs --vertical all --horizon-days 90",
    "seed:generate:120": "node scripts/seed/generate.mjs --vertical all --horizon-days 120",
    "seed:generate:180": "node scripts/seed/generate.mjs --vertical all --horizon-days 180",
    "seed:regenerate": "node scripts/seed/generate.mjs --vertical all",
    "qa:guided-booking": "node scripts/validate/guided-booking-qa.mjs",
    "smoke:trips": "node scripts/validate/trip-pricing-smoke.mjs",
    "start": "vite --open --mode ssr",
    "qwik": "qwik"
  },
  "devDependencies": {
    "@builder.io/qwik": "^1.19.0",
    "@builder.io/qwik-city": "^1.19.0",
    "@eslint/js": "latest",
    "@resvg/resvg-js": "^2.6.2",
    "@tailwindcss/postcss": "^4.2.1",
    "@types/node": "20.19.0",
    "drizzle-kit": "^0.31.9",
    "eslint": "9.32.0",
    "eslint-plugin-qwik": "^1.19.0",
    "globals": "16.4.0",
    "postcss": "^8.5.6",
    "prettier": "3.6.2",
    "tailwindcss": "^4.2.1",
    "typescript": "5.4.5",
    "typescript-eslint": "8.38.0",
    "typescript-plugin-css-modules": "latest",
    "undici": "*",
    "vite": "7.3.1",
    "vite-tsconfig-paths": "^4.2.1",
    "vitest": "^4.0.18"
  },
  "dependencies": {
    "@fontsource-variable/lexend": "^5.2.11",
    "@fontsource/poppins": "^5.2.7",
    "drizzle-orm": "^0.45.1",
    "pg": "^8.20.0",
    "zod": "^3.25.48"
  }
}
